# Required: comma-separated client bearer tokens allowed to call this proxy.
INBOUND_API_KEYS=change-me
# Required: OpenAI-compatible upstream /v1 base URL.
UPSTREAM_BASE_URL=http://127.0.0.1:8000/v1
# Required when your upstream needs authentication.
UPSTREAM_API_KEY=

# Privacy model used to redact multilingual PII.
PRIVACY_MODEL_ID=OpenMed/privacy-filter-multilingual
# DEVICE=auto
# TORCH_DTYPE=auto
# TRUST_REMOTE_CODE=true
# FILTER_OUTPUT=true
# MIN_ENTITY_SCORE=0.50
# MODEL_SUFFIX=-anonym
# METRICS_REQUIRE_AUTH=true
# LOG_LEVEL=info
# HOST=0.0.0.0
# PORT=8088
# MODEL_IDLE_UNLOAD_SECONDS=300
